# docker-compose.yml이 참조하는 값들.
# 이 파일을 .env로 복사해서 실제 값을 채워넣으세요 (.env는 git에 안 올라감).
#   cp .env.example .env

# 도커 안에서 새로 뜨는 MySQL 전용 root 비밀번호 (로컬에 이미 설치된 MySQL과는 별개)
MYSQL_ROOT_PASSWORD=change_me

# JWT 서명 키. 로컬 개발용 application-secret.properties의 app.jwtSecret과 달라도 무방
APP_JWT_SECRET=change_me

# 카카오 지도 JS 키 (frontend/.env에 있는 값과 동일한 걸 써도 됨)
# 단, Kakao Developers 콘솔의 플랫폼 등록 도메인에 http://localhost:3000 이 있어야 지도가 뜸
REACT_APP_KAKAO_MAPS_API_KEY=change_me

# 아이디 찾기/비밀번호 재설정 이메일 발송용 (선택 - 비워두면 그 기능만 동작 안 함)
MAIL_USERNAME=
MAIL_PASSWORD=
